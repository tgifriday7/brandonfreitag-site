---
import Base from '../layouts/Base.astro';
---

<Base title="Home">
  <div class="home">
    <p class="positioning">Strategies fail more often than they should. I change that.</p>
    <p class="bio">Brandon Freitag works at the intersection of strategy, structure and execution. He has spent his career inside large-scale organizational change, both helping companies make the case for it and owning the outcome as an executive.</p>
  </div>
</Base>

<style>
  .home {
    padding-top: 3rem;
  }

  .positioning {
    font-size: 3.25rem;
    font-weight: 700;
    line-height: 1.2;
    color: #0F3460;
    margin-bottom: 2rem;
  }

  .bio {
    font-size: 1rem;
    line-height: 1.7;
    color: #1A1A1A;
    margin-bottom: 2.5rem;
    max-width: 600px;
  }

  .home-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0;
    border: none;
    margin: 0;
  }

  .home-links a {
    font-size: 1rem;
    color: #0F3460;
    text-decoration: underline;
    text-underline-offset: 3px;
    display: inline;
  }
</style>
