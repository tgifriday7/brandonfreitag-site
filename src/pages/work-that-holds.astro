---
import Base from '../layouts/Base.astro';

const seriesPapers = [
  {
    title: "The Five Breakpoints Leaders Miss",
    description: "The five predictable failure patterns that derail large-scale change and why they are almost always visible before they become costly.",
    url: "https://brandonfreitag.substack.com/p/the-five-breakpoints-leaders-miss",
  },
  {
    title: "The Stewardship Gap",
    description: "Why leaders who understand change conceptually still fail to produce it and what separates intent from structural ownership.",
    url: "https://www.workthatholds.com/p/the-stewardship-gap",
  },
  {
    title: "Designed to Stall",
    description: "The organizational design decisions that make failure the path of least resistance and how to recognize them before they are built in.",
    url: "https://www.workthatholds.com/p/designed-to-stall",
  },
  {
    title: "The AI Mirror",
    description: "What your AI deployment reveals about the organization around it.",
    url: "https://www.workthatholds.com/p/the-ai-mirror",
  },
  {
    title: "Before It Breaks",
    description: "Seven disciplines for leaders who want to build something that holds, applied before the launch, not after the stall.",
    url: "https://www.workthatholds.com/p/before-it-breaks",
  },
  {
    title: "The Leader the Work Requires",
    description: "What the leader actually believes about the people they lead and whether they will act on it when it costs something: the question the rest of this series couldn't reach.",
    url: "https://www.workthatholds.com/p/the-leader-the-work-requires",
  },
];

const practicePapers = [
  {
    title: "Your AI Agent Won't Save You",
    description: "The five breakpoints explain why enterprise AI deployments fail before the technology gets blamed.",
    url: "https://www.workthatholds.com/p/your-ai-agent-wont-save-you",
  },
  {
    title: "The Win Rate Illusion",
    date: "June 16",
    description: "Two illusions the sales industry stopped questioning and the measurement system that sustains both.",
    url: null,
  },
  {
    title: "The Flaw in Forward Deployment",
    date: "June 23",
    description: "Why the Forward Deployed Engineer model solves the wrong problem, and what a complete model requires.",
    url: null,
  },
  {
    title: "The Band-Aid Problem",
    date: "June 30",
    description: "The AI governance conversation is happening at the wrong altitude. The real problem is upstream.",
    url: null,
  },
];
---

<Base title="Work That Holds" description="A six-paper series on the structural reasons large-scale initiatives break down and the disciplines required to address them before they do.">
  <h1>Work That Holds</h1>

  <p>Seventy percent of large initiatives fail. Most of the remaining thirty percent deliver something less than what was promised. The conditions for both outcomes were set before the work began.</p>

  <p><a href="https://workthatholds.com" target="_blank" rel="noopener noreferrer">Work That Holds</a> is a publication for senior leaders who want an honest read on why that happens and what it actually takes to build something that holds.</p>

  <h2>The Why Change Fails series</h2>

  <ol class="paper-list">
    {seriesPapers.map((paper) => (
      <li class="paper-item">
        <a href={paper.url} target="_blank" rel="noopener noreferrer" class="paper-title">{paper.title}</a>
        <p class="paper-description">{paper.description}</p>
      </li>
    ))}
  </ol>

  <h2>The Work in Practice</h2>

  <ol class="paper-list">
    {practicePapers.map((paper) => (
      <li class="paper-item">
        {paper.url ? (
          <a href={paper.url} target="_blank" rel="noopener noreferrer" class="paper-title">{paper.title}</a>
        ) : (
          <span class="paper-title paper-title--upcoming">{paper.title} <span class="paper-date">{paper.date}</span></span>
        )}
        <p class="paper-description">{paper.description}</p>
      </li>
    ))}
  </ol>

  <p class="archive-link">
    <a href="https://workthatholds.com" target="_blank" rel="noopener noreferrer">Read the full Work That Holds archive on Substack</a>
  </p>
</Base>

<style>
  h2 {
    margin-top: 2.5rem;
  }

  .paper-list {
    list-style: none;
    margin: 0 0 2.5rem 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .paper-item {
    border-top: 1px solid #E5E5E5;
    padding-top: 1.5rem;
  }

  .paper-title {
    display: block;
    font-weight: 700;
    font-size: 1rem;
    color: #0F3460;
    text-decoration: underline;
    text-underline-offset: 3px;
    margin-bottom: 0.5rem;
  }

  .paper-title--upcoming {
    color: #6B6B6B;
    text-decoration: none;
    cursor: default;
  }

  .paper-date {
    font-weight: 400;
    font-size: 0.875rem;
    color: #6B6B6B;
  }

  .paper-description {
    font-size: 0.95rem;
    color: #6B6B6B;
    line-height: 1.6;
    margin: 0;
  }

  .archive-link {
    border-top: 1px solid #E5E5E5;
    padding-top: 1.5rem;
    margin-top: 0;
  }

  .archive-link a {
    font-size: 0.95rem;
  }
</style>
